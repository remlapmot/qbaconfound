Package: qbaconfound
Title: Monte Carlo Quantitative Bias Analysis for Unmeasured Confounding
Version: 0.0.0.9000
Authors@R: c(
    person("Tom", "Palmer", , "remlapmot@hotmail.com", role = c("aut", "cre"),
           comment = c(ORCID = "0000-0003-4655-4511", ROR = "0524sp257")),
